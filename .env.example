# The Racing API credentials
# Get these from your dashboard at https://www.theracingapi.com/dashboard
RACING_API_USERNAME=your_username_here
RACING_API_PASSWORD=your_password_here
RACING_API_BASE_URL=https://api.theracingapi.com/v1

# Server settings (for HTTP/SSE mode)
MCP_HOST=0.0.0.0
MCP_PORT=8080

# Cache TTL settings (seconds)
CACHE_TTL_STATIC=86400      # 24h for courses/regions (never change)
CACHE_TTL_RACECARDS=180     # 3 min for live racecards (matches API refresh)
CACHE_TTL_RESULTS=180       # 3 min for today's results
CACHE_TTL_ANALYSIS=900      # 15 min for historical analysis
CACHE_TTL_SEARCH=3600       # 1h for name→ID lookups
